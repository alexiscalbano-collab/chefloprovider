# ============================================================
# VARIABLES D'ENVIRONNEMENT — chefloprovider
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans git
# ============================================================

# Base de données Neon
# Créer un projet sur https://neon.tech → copier la connection string
DATABASE_URL=postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# NextAuth
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# En production (Vercel par exemple)
# NEXTAUTH_URL=https://votre-domaine.vercel.app
